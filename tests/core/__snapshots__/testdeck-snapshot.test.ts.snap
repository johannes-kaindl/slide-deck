    "kairo": ".sd-slide{ --sd-bg:#0d0f10; --sd-fg:#e7eae6; --sd-accent:#4ac8d8; --sd-code-bg:#11181a; --sd-font:"Inter", system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; --sd-heading-font:"EB Garamond", "Iowan Old Style", "Palatino Linotype", Palatino, Georgia, serif; --sd-mono:"JetBrains Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace; --sd-muted:#8ea0a2; --sd-surface:#11181a; --sd-callout-fg:#e7eae6; --sd-display-style:italic; --sd-display-weight:500; --sd-display-tracking:-0.02em; --sd-eyebrow-font:var(--sd-mono); --sd-base:28px; }
.sd-slide{
