{
  "name": "slide-deck",
  "version": "0.1.0",
  "description": "Turn a Markdown note into a slide deck and export it to PDF or a PNG image series, with live readability checks.",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs --production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:obsidian": "eslint src",
    "lint:portal": "eslint src --config eslint.portal.config.mjs",
    "deploy": "npm run build && cp main.js manifest.json styles.css \"${OBSIDIAN_PLUGIN_DIR:?set OBSIDIAN_PLUGIN_DIR}\"/",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json package.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "author": "Johannes Kaindl",
  "license": "AGPL-3.0-or-later",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20",
    "esbuild": "^0.23",
    "eslint": "^9",
    "eslint-plugin-obsidianmd": "latest",
    "obsidian": "latest",
    "typescript": "^5.5",
    "typescript-eslint": "^8",
    "vitest": "^2"
  },
  "dependencies": {
    "@vscode/markdown-it-katex": "^1.1.2",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0"
  }
}
